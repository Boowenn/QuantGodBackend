# QuantGod local environment template.
# Copy to a private file, fill only what you need, and source it before running tools.
# Never commit a filled env file.

# Local dashboard server.
QG_DASHBOARD_HOST=127.0.0.1
QG_DASHBOARD_PORT=8080
QG_PYTHON_BIN=python3

# Runtime data source.
# On Mac/Linux, use a repo-local folder for imported read-only research snapshots.
# If MT5 is installed locally, QG_MAC_RUNTIME_SOURCE=auto promotes an imported
# mac snapshot path to the live Wine MQL5/Files folder so the dashboard does
# not freeze on the migration bundle.
# On Windows MT5, set this to the HFM MT5 Files folder.
QG_RUNTIME_DIR=./Dashboard
QG_MT5_FILES_DIR=./Dashboard
QG_MAC_RUNTIME_SOURCE=auto
QG_READONLY_MODE=1

# MT5 bridge/client. Leave empty on Mac unless running MT5 through Windows/Wine/remote access.
QG_MT5_TERMINAL_PATH=
QG_MT5_START_MODE=shadow
QG_MT5_START_SYMBOL=USDJPYc
# Repo default is 1000000 so MT5 CopyRates can cover 6-12 months of M1 bars.
# On memory-constrained Macs, override privately in .env.local, for example
# QG_MT5_MAX_BARS=300000.
QG_MT5_MAX_BARS=1000000
# Keep live launch explicitly gated even when QG_MT5_START_MODE=live.
QG_MT5_LIVE_LAUNCH_ALLOWED=0
QG_MT5_TRADING_ENABLED=false
QG_MT5_ADAPTIVE_APPLY_ENABLED=false

# Safe daily automation loop. It refreshes evidence, builds same-day todo
# queues, and writes DailyReview. Tester launch remains guarded and disabled
# by default; live promotion is recommendation-only and never auto-applied.
QG_DAILY_AUTOPILOT_ENABLED=1
QG_DAILY_AUTOPILOT_INTERVAL_MINUTES=60
QG_DAILY_AUTOPILOT_ALLOW_TESTER_RUN=0
QG_DAILY_AUTOPILOT_MAX_TASKS=5

# Runtime log maintenance. Active *.log files above this size are gzipped into
# runtime/log_archive and then truncated in place; archived logs older than the
# retention window are deleted.
QG_RUNTIME_LOG_MAX_MB=128
QG_RUNTIME_LOG_RETENTION_DAYS=2

# ParamLab guarded Strategy Tester automation.
# Keep this pointed at an isolated tester copy, never the live HFM pilot root.
QG_PARAMLAB_HFM_ROOT=./runtime/ParamLab_Tester_Sandbox/live_hfm_placeholder
QG_PARAMLAB_TESTER_ROOT=./runtime/HFM_MT5_Tester_Isolated
QG_MT5_TESTER_ROOT=./runtime/HFM_MT5_Tester_Isolated

# Polymarket AI scoring. Optional; without a key the scorer falls back to rule/history mode.
QG_POLYMARKET_HISTORY_DB=./archive/polymarket/history/QuantGod_PolymarketHistory.sqlite
QG_POLYMARKET_LLM_ENV_FILE=./.env.local
QG_POLYMARKET_LLM_MODEL=gpt-4o-mini
QG_POLYMARKET_OPENAI_API_KEY=
QG_POLYMARKET_OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Polymarket canary executor. Keep disabled until dry-run/outcome evidence is intentionally promoted.
QG_POLYMARKET_REAL_EXECUTION=false
QG_POLYMARKET_CANARY_ACK=
QG_POLYMARKET_CANARY_KILL_SWITCH=true
QG_POLYMARKET_WALLET_ADAPTER=
QG_POLYMARKET_PRIVATE_KEY=
QG_POLYMARKET_CLOB_HOST=https://clob.polymarket.com
QG_POLYMARKET_CHAIN_ID=137
QG_POLYMARKET_FUNDER=
QG_POLYMARKET_CANARY_TOKEN_ID=

# Optional Cloudflare dashboard sync.
QG_INGEST_TOKEN=

# Phase 2 Telegram push notifications. Keep real secrets in .env.local, not Git.
TELEGRAM_BOT_TOKEN=
# set locally
TELEGRAM_CHAT_ID=
QG_NOTIFY_ENABLED=true
NOTIFY_TRADE_SIGNAL=true
NOTIFY_RISK_ALERT=true
NOTIFY_AI_SUMMARY=true
NOTIFY_DAILY_DIGEST=true
NOTIFY_GOVERNANCE=false

# MT5 Telegram DeepSeek analysis. Keep real key in .env.deepseek.local, not Git.
QG_MT5_AI_DEEPSEEK_ENABLED=0
QG_MT5_AI_DEEPSEEK_MODEL=deepseek-v4-flash
QG_MT5_AI_DEEPSEEK_ENV_FILE=.env.deepseek.local
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_API_KEY=
